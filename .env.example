# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: structured hiring + technographic signals (https://theirstack.com)
# Without it, these signals fall back to LLM web search.
THEIRSTACK_API_KEY=

# Optional: calendar auto-brief via secret ICS feed (no OAuth)
# Google Calendar: Settings -> your calendar -> "Secret address in iCal format"
# Outlook: Settings -> Shared calendars -> Publish -> ICS link
CALENDAR_ICS_URL=
# Your own email domain(s), comma-separated — attendees from these are ignored
OWN_EMAIL_DOMAINS=yourcompany.com

# Optional: HubSpot CRM sync (private app token)
# HubSpot: Settings -> Integrations -> Private Apps -> create with CRM scopes
HUBSPOT_ACCESS_TOKEN=

# v2.0 — Team mode (optional). Set DATABASE_URL to enable Postgres storage,
# accounts/login, and shared workspace memory. Unset = single-user file mode.
DATABASE_URL=
# Session-signing secret for team mode (any long random string)
AUTH_SECRET=

# v2.0 — Google Calendar OAuth (optional; ICS feed above remains the fallback)
# Google Cloud Console -> OAuth client (web) -> add the redirect URI below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
APP_URL=http://localhost:3000

# v2.0 — Salesforce sync (optional; via Connected App or `sf org display`)
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=

# Optional overrides
SALESRX_MODEL=claude-sonnet-5
SALESRX_MAX_WEB_SEARCHES=8
SALESRX_CACHE_TTL_HOURS=24
